# Database — host must be the Compose service name "db" when running in Docker
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=transactions
DATABASE_URL=postgresql://app:app@db:5432/transactions

# Redis / Celery — host must be the Compose service name "redis"
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Groq LLM
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# Pipeline tuning
LLM_BATCH_SIZE=20
LLM_MAX_RETRIES=3

# App
MAX_UPLOAD_MB=10
LOG_LEVEL=INFO
ENV=development
